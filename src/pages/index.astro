---
import Layout from "../layouts/Layout.astro";

const profile = {
  name: "Sofia Maria Lo Cicero Vaina",
  links: {
    scholar: "https://scholar.google.com/citations?user=JwIwNoEAAAAJ&hl=ru",
    github: "https://github.com/2son1a",
    linkedin: "https://www.linkedin.com/in/sofia-maria-lo-cicero-vaina-8a853b238/",
    email: "mailto:s.lochichero@gmail.com",
  },
  interests:
    "Hi there! [taking-pictures]<br/>I have just finished a 9-month research internship at Together AI. Now I am looking for my next opportunity. I want it to be about understanding how things work — for example, mechanistic interpretability, training dynamics, or factual recall.",
  publications: [
    {
      authorship: "First author",
      title: "Mashup Learning: Faster Finetuning by Remixing Past Checkpoints",
      url: "https://arxiv.org/abs/2603.10156",
      details: "2026; under review at ",
      venue: "ICML",
    },
    {
      authorship: "First author",
      title: "Diffusion Language Models Generation Can Be Halted Early",
      url: "https://arxiv.org/abs/2305.10818",
      details: "2023",
    },
    {
      authorship: "Co-author",
      title:
        "Linear Transformers with Learnable Kernel Functions are Better In-Context Models",
      url: "https://arxiv.org/abs/2402.10644",
      details: "",
      venue: "ACL ",
      venueYear: "2024",
    },
  ],
  experiences: [
    {
      role: "Research Scientist Intern",
      organization: "Together AI",
      url: "https://www.together.ai/",
      period: "Jul 2025 – Mar 2026",
      details: [
        "Proposed Mashup Learning, a method that selects and merges historical finetuning checkpoints to construct improved initializations for new tasks.",
        "Demonstrated consistent accuracy gains of 0.5–5 pp over training from scratch across 4 models (Gemma-3 4B/1B, Gemma-2 2B, Mistral-7B), 8 benchmarks, and both LoRA and full finetuning setups.",
        "Achieved 41–46% fewer training steps and up to 37% less wall-clock time to match from-scratch accuracy, including all selection and merging overhead.",
        'First-authored paper submitted to ICML 2026; code available at <a href="https://github.com/2son1a/mashup-learning">GitHub</a>.',
      ],
    },
    {
      role: "Research Fellow",
      organization: "Cambridge AI Safety Hub",
      url: "https://www.cambridgeaisafety.org/",
      period: "Jan 2025 – Apr 2025",
      details: [
        "Tested a circuit transplantation mechanistic interpretability proposal for training LLMs around specific circuits extracted from pretrained models.",
      ],
    },
    {
      role: "Research Scientist Intern",
      organization: "T-Bank (Tinkoff) & MIPT",
      url: "https://en.wikipedia.org/wiki/T-Bank",
      period: "May 2023 – Mar 2024",
      details: [
        "First-authored a paper identifying a design flaw in Diffusion Language Models that causes slower generation; co-authored a paper on State Space Models and in-context learning, published at ACL 2024.",
        "Presented findings to audiences of 50–200 people on 4 occasions.",
      ],
    },
    {
      role: "Founder & CEO",
      organization: "Marker",
      subtitle: "An AI-powered Russian-language writing assistant",
      period: "Sep 2021 – May 2023",
      details: [
        "Raised $50,000 from a private investor, state grants, and a corporation.",
        "Built and led a team of 10 engineers, designers, and marketers.",
        "Developed an NLP-based MVP and validated product-market fit through user testing and acquisition experiments.",
      ],
    },
    {
      role: "Research Scientist Intern",
      organization: "Sberbank",
      url: "https://en.wikipedia.org/wiki/Sberbank",
      period: "Apr 2021 – Jun 2021",
      details: [
        "Implemented a GAN to automate paraphrasing of gendered voice assistant phrases.",
      ],
    },
  ],
  education: [
    {
      institution: "Innopolis University",
      url: "https://innopolis.university/en/",
      location: "Kazan, Russia",
      period: "Sep 2020 – May 2024",
      details: "Bachelor's in Computer Science, specializing in <strong>AI</strong>.",
    },
  ],
  competitions: [
    {
      period: "2020 – 2021",
      details:
        '<strong>Technical Hackathons:</strong> <strong>4</strong> top placements including <strong>1st place</strong> in <em>Leaders Of Digital</em> final and <em>SberCode</em> competitions; <strong>$18,500</strong> in total prizes.',
    },
    {
      period: "2019 – 2020",
      details:
        '<strong>Mathematical Olympiads:</strong> <strong>1st</strong> and <strong>2nd place</strong> in Crimea regional semi-finals of the <em>Russian Mathematical Olympiad</em>, top <strong>0.5%</strong> among 500 participants.',
    },
  ],
};

---

<Layout title={`${profile.name} - Notes`}>
  <main class="note-shell">
    <article class="note">
      <header class="note-header">
        <h1>{profile.name}</h1>
        <p class="profile-links">
          <a href={profile.links.scholar}>Google Scholar</a>
          <a href={profile.links.github}>GitHub</a>
          <a href={profile.links.linkedin}>LinkedIn</a>
          <a href={profile.links.email}>Email: s.lochichero@gmail.com</a>
        </p>
        <div class="intro-row">
          <img src={`${import.meta.env.BASE_URL}/profile.png`} alt={profile.name} class="profile-photo" />
          <p class="interests" set:html={profile.interests.replace(/\[taking-pictures\]/g, `<img src="${import.meta.env.BASE_URL}/taking-pictures.png" alt="taking pictures" class="inline-icon" />`)} />
        </div>
      </header>

      <section aria-labelledby="publications-heading">
        <h2 id="publications-heading">Publications <a href={profile.links.scholar} class="heading-link">[Google Scholar]</a></h2>
        <div class="entry-list publications">
          {profile.publications.map((item) => (
            <p>
              <strong>{item.authorship}</strong>, <a href={item.url}><em>{item.title}</em></a>; {item.details}{item.venue && <><strong>{item.venue}</strong></>}{item.venueYear && <> {item.venueYear}</>}.
            </p>
          ))}
        </div>
      </section>

      <section aria-labelledby="experience-heading">
        <h2 id="experience-heading">Experience</h2>
        <div class="entry-list">
          {profile.experiences.map((item) => (
            <article class="entry-item">
              <div class="entry-body">
                <p>
                  {item.url ? <a href={item.url}><strong>{item.organization}</strong></a> : <strong>{item.organization}</strong>}, <em>{item.role}</em>
                </p>
                {item.subtitle && <p class="subline">{item.subtitle}</p>}
                <ul>
                  {item.details.map((d) => (
                    <li set:html={d} />
                  ))}
                </ul>
              </div>
              <span class="entry-date">{item.period}</span>
            </article>
          ))}
        </div>
      </section>

      <section aria-labelledby="education-heading">
        <h2 id="education-heading">Education</h2>
        <div class="entry-list">
          {profile.education.map((item) => (
            <article class="entry-item">
              <div class="entry-body">
                <p>
                  {item.url ? <a href={item.url}><strong>{item.institution}</strong></a> : <strong>{item.institution}</strong>}{item.location && <> ({item.location})</>}
                </p>
                <p set:html={item.details} />
              </div>
              <span class="entry-date">{item.period}</span>
            </article>
          ))}
        </div>
      </section>

      <section aria-labelledby="competitions-heading">
        <h2 id="competitions-heading">Competitions</h2>
        <div class="entry-list">
          {profile.competitions.map((item) => (
            <article class="entry-item">
              <div class="entry-body">
                <p set:html={item.details} />
              </div>
              <span class="entry-date">{item.period}</span>
            </article>
          ))}
        </div>
      </section>
    </article>
  </main>

</Layout>

<style>
  :global(html),
  :global(body) {
    background: #fbfbfb;
    color: #1f2933;
  }

  :global(a) {
    color: #64c8d1;
  }

  :global(a:hover) {
    color: #d16d64;
  }

  .note-shell {
    min-height: 100dvh;
    display: flex;
    justify-content: center;
    padding: 2rem 1rem 4rem;
  }

  .note {
    width: min(100%, 860px);
    padding: 0 0.5rem;
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    line-height: 1.7;
  }

  .note-header {
    margin-bottom: 2rem;
  }

  .profile-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin-bottom: 0.8rem;
  }

  .profile-links a {
    white-space: nowrap;
  }

  .intro-row {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .profile-photo {
    width: 140px;
    height: 140px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .intro-row .interests {
    margin-bottom: 0;
  }

  @media (max-width: 520px) {
    .intro-row {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }

  h1,
  h2 {
    color: #0f172a;
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 0.7rem;
  }

  h1 {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
  }

  h2 {
    font-size: 1.4rem;
    margin-top: 0;
  }

  section {
    margin-top: 2rem;
  }

  p {
    margin-bottom: 0.65rem;
    color: #334155;
  }

  .entry-item ul {
    padding-left: 1.3rem;
    margin-top: 0.2rem;
  }

  .entry-item li {
    margin-bottom: 0.3rem;
    color: #334155;
  }

  .entry-list {
    display: grid;
    gap: 0.8rem;
  }

  .publications {
    gap: 0.25rem;
  }

  .publications p {
    margin-bottom: 0;
  }

  .entry-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0 2rem;
  }

  .entry-date {
    white-space: nowrap;
    color: #64748b;
    text-align: right;
  }

  .entry-body p:last-child {
    margin-bottom: 0;
  }

  .subline {
    color: #64748b;
    font-style: italic;
  }

  .heading-link {
    font-size: 0.85rem;
    font-weight: 400;
  }

  :global(.inline-icon) {
    height: 1em;
    width: auto;
    vertical-align: middle;
    display: inline;
  }

</style>
