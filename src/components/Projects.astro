---
const projects = [
  {
    title: "Project One",
    description: "A brief description of the project and what it does. Replace this with your own.",
    url: "#",
  },
  {
    title: "Project Two",
    description: "Another project you're proud of. Describe what makes it interesting.",
    url: "#",
  },
  {
    title: "Project Three",
    description: "One more to round out the grid. Swap in your real work.",
    url: "#",
  },
];
---

<section id="projects" class="projects">
  <div class="container">
    <h2>Projects</h2>
    <div class="grid">
      {projects.map((project) => (
        <a href={project.url} class="card">
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <span class="arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding-block: clamp(4rem, 10vw, 8rem);
  }

  h2 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    gap: 1.25rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-subtle);
    color: var(--text);
    transition: border-color 0.2s, transform 0.2s;
  }

  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    color: var(--text);
  }

  .card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex: 1;
  }

  .arrow {
    display: inline-block;
    margin-top: 1rem;
    color: var(--accent);
    font-size: 1.1rem;
    transition: transform 0.2s;
  }

  .card:hover .arrow {
    transform: translateX(4px);
  }
</style>
